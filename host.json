{
  "version": "2.0",
  "extensions": {
    "queues": {
      "batchSize": 2,
      "newBatchThreshold": 1,
      "maxPollingInterval": "00:02:00",
      "maxDequeueCount": 5,
      "visibilityTimeout": "00:10:00"
    }
  },
  "functionTimeout": "01:00:00",
  "logging": {
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true,
        "maxTelemetryItemsPerSecond": 20
      }
    }
  }
}
